<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Form Pendaftaran Seminar"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"
                    android:layout_marginBottom="20dp"
                    android:layout_gravity="center"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNamaSeminar"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nama Lengkap"
                    android:textColorHint="#000000"
                    app:hintTextColor="#000000"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="#000000"
                    app:boxStrokeColor="#000000">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNamaSeminar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#000000"
                        android:textCursorDrawable="@null" />
                </com.google.android.material.textfield.TextInputLayout>





                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmailSeminar"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Email"
                    android:textColorHint="#000000"
                    app:hintTextColor="#000000"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#000000"
                    app:boxStrokeColor="#000000">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmailSeminar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#000000"
                        android:textCursorDrawable="@null" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPhoneSeminar"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Nomor HP"
                    android:textColorHint="#000000"
                    app:hintTextColor="#000000"
                    app:startIconDrawable="@android:drawable/stat_sys_phone_call"
                    app:startIconTint="#000000"
                    app:boxStrokeColor="#000000">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPhoneSeminar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="13"
                        android:textColor="#000000"
                        android:textCursorDrawable="@null" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jurusan / Program Studi"
                    android:layout_marginTop="16dp"
                    android:textStyle="bold"
                    android:textColor="#000000"/>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_spinner">
                    <Spinner
                        android:id="@+id/spinnerProdi"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pilih Tema Seminar"
                    android:layout_marginTop="16dp"
                    android:textStyle="bold"
                    android:textColor="#000000"/>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/bg_spinner">
                    <Spinner
                        android:id="@+id/spinnerSeminar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jenis Kelamin"
                    android:layout_marginTop="16dp"
                    android:textStyle="bold"
                    android:textColor="#000000"/>
                <RadioGroup
                    android:id="@+id/rgGenderSeminar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <RadioButton
                        android:id="@+id/rbMaleSeminar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laki-laki"
                        android:textColor="#000000"
                        app:useMaterialThemeColors="false"
                        android:buttonTint="#000000"/>

                    <RadioButton
                        android:id="@+id/rbFemaleSeminar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:text="Perempuan"
                        android:textColor="#000000"
                        app:useMaterialThemeColors="false"
                        android:buttonTint="#000000"/>
                </RadioGroup>

                <CheckBox
                    android:id="@+id/cbAgreement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Saya menyatakan data ini benar"
                    android:textColor="#000000"
                    app:useMaterialThemeColors="false"
                    android:buttonTint="#000000"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnSubmitSeminar"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="#1A237E"
                    android:text="DAFTAR SEKARANG"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:cornerRadius="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="60dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>